# Local dev — copy to .env and source it before `mvn spring-boot:run`,
# or set these as env vars in your hosting provider's dashboard.

# JDBC URL for Postgres
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/studyplanner
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=postgres

# JWT signing key — must be at least 32 bytes (any random string works).
# Generate one: `openssl rand -base64 48`
JWT_SECRET=replace-me-with-a-long-random-string-min-32-bytes

# Comma-separated list of allowed frontend origins
CORS_ALLOWED_ORIGINS=http://localhost:5173,https://your-frontend.vercel.app
